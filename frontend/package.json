{
  "name": "ffmpeg-gui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:backend": "node scripts/build-backend.cjs",
    "build": "tsc && npm run build:backend && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
